[bullsys]
[profile]
command="echo building default profile..."
compiler="gcc"
include="iniparser"
source="src/"
output="bin/bullsys"
[profile:release]
command="echo building release profile..."
compiler="gcc"
flags="-Wall -Wextra -std=c99 -pedantic -O2 -D_POSIX_C_SOURCE=200809L"
include="iniparser"
source="src/"
output="bin/bullsys"
[clean]
command="rm -rf bin/"
[run]
command="bin/bullsys"